# 智能列名识别
# ─────────────────────────────────────────
def _normalize(s: str) -> str:
    """小写 + 去除多余空白/下划线/连字符，方便模糊匹配"""
    return re.sub(r'[\s_\-]+', ' ', s.lower()).strip()


def auto_detect_columns(columns: list) -> dict:
    """
    返回 {slot_name: matched_column_name | None}
    采用贪心策略：优先精确子串匹配，再考虑关键词顺序。
    每个列只能映射到一个槽。
    """
    norm_cols = {col: _normalize(col) for col in columns}
    result    = {slot: None for slot in SLOT_ORDER}
    used_cols = set()

    slot_priority = ['桨距角1', '桨距角2', '桨距角3', '有功功率', '转速',
                     '风速', '风向', '齿轮箱温度']

    for slot in slot_priority:
        if slot not in SEMANTIC_SLOTS:
            continue
        keywords   = [_normalize(k) for k in SEMANTIC_SLOTS[slot]['keywords']]
        best_col   = None
        best_score = -1

        for col, norm_col in norm_cols.items():
            if col in used_cols:
                continue
            for rank, kw in enumerate(keywords):
                if norm_col == kw:
                    score = 1000 - rank
                elif kw in norm_col or norm_col in kw:
                    score = 500 - rank
                else:
                    continue
                if score > best_score:
                    best_score = score
                    best_col   = col

        if best_col:
            result[slot] = best_col
            used_cols.add(best_col)

    return result


# ─────────────────────────────────────────
# 滑动窗口 / 风速推断 / 标签数据库
# ─────────────────────────────────────────
def sliding_window(data: np.ndarray, W: int, S: int) -> np.ndarray:
    N, D = data.shape
    starts = list(range(0, N - W + 1, S))
    if not starts:
        return np.empty((0, W, D), dtype=np.float32)
    return np.stack([data[i:i + W] for i in starts])


def infer_wind_level(seg: np.ndarray, wind_slot_idx: int) -> str:
    """wind_slot_idx 是信号槽在全量列数组中的列下标"""
    if wind_slot_idx < 0 or wind_slot_idx >= seg.shape[1]:
        return '未知风速'
    avg_wind = float(np.nanmean(seg[:, wind_slot_idx]))
    for name, (lo, hi) in WIND_LEVELS.items():
        if lo <= avg_wind < hi:
            return f'{name}({lo}-{hi}m/s)'
    return '超高风速'


def load_label_db(path: str = LABEL_DB_PATH) -> dict:
    if os.path.exists(path):
        with open(path, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {}


def save_label_db(db: dict, path: str = LABEL_DB_PATH):
    with open(path, 'w', encoding='utf-8') as f:
        json.dump(db, f, ensure_ascii=False, indent=2)


