class ColumnMappingDialog(tk.Toplevel):
    """显示自动识别结果，允许用户手动调整映射"""
    def __init__(self, parent, col_map: dict, all_columns: list):
        super().__init__(parent)
        self.title("📋 列名自动识别结果")
        self.configure(bg="#1E1E2E")
        self.resizable(False, False)
        self.grab_set()
        self.result   = None           # None = 取消
        self._all_cols = ['（不使用）'] + all_columns
        self._vars: dict = {}

        self._build(col_map, all_columns)
        self.wait_window()

    def _build(self, col_map, all_columns):
        tk.Label(self, text="自动识别的信号列映射", bg="#1E1E2E", fg="#7EB8F7",
                 font=("Consolas", 11, "bold")).pack(pady=(12, 4))
        tk.Label(self, text="请确认或手动修正。绿色=已识别，橙色=未匹配",
                 bg="#1E1E2E", fg="#888", font=("Consolas", 8)).pack(pady=(0, 8))

        grid = tk.Frame(self, bg="#252535", padx=12, pady=8)
        grid.pack(fill=tk.BOTH, padx=16, pady=4)

        headers = ["信号槽", "识别到的列名", "状态", "手动选择"]
        for col_i, h in enumerate(headers):
            tk.Label(grid, text=h, bg="#252535", fg="#7EB8F7",
                     font=("Consolas", 9, "bold"), padx=8).grid(row=0, column=col_i, sticky="w")
        ttk.Separator(grid, orient=tk.HORIZONTAL).grid(
            row=1, column=0, columnspan=4, sticky="ew", pady=4)

        for row_i, slot in enumerate(SLOT_ORDER, start=2):
            matched = col_map.get(slot)
            color   = "#4CAF50" if matched else "#FF9800"
            conf    = "✅ 已匹配" if matched else "❌ 未识别"

            tk.Label(grid, text=slot, bg="#252535", fg=color,
                     font=("Consolas", 9, "bold"), padx=6).grid(
                         row=row_i, column=0, sticky="w", pady=2)
            tk.Label(grid, text=matched or "—", bg="#252535", fg="#DDD",
                     font=("Consolas", 8), padx=6).grid(
                         row=row_i, column=1, sticky="w")
            tk.Label(grid, text=conf, bg="#252535", fg=color,
                     font=("Consolas", 8), padx=6).grid(
                         row=row_i, column=2, sticky="w")

            var = tk.StringVar(value=matched if matched else '（不使用）')
            self._vars[slot] = var
            cb = ttk.Combobox(grid, textvariable=var, values=self._all_cols,
                              width=28, state="readonly", font=("Consolas", 8))
            cb.grid(row=row_i, column=3, padx=6, pady=2)

        btn_frame = tk.Frame(self, bg="#1E1E2E")
        btn_frame.pack(pady=12)
        tk.Button(btn_frame, text="✅ 确认并加载", command=self._confirm,
                  bg="#4CAF50", fg="white", relief=tk.FLAT,
                  font=("Consolas", 10, "bold"), padx=16, pady=6,
                  cursor="hand2").pack(side=tk.LEFT, padx=8)
        tk.Button(btn_frame, text="❌ 取消", command=self.destroy,
                  bg="#F44336", fg="white", relief=tk.FLAT,
                  font=("Consolas", 10, "bold"), padx=16, pady=6,
                  cursor="hand2").pack(side=tk.LEFT, padx=8)

    def _confirm(self):
        final = {}
        for slot, var in self._vars.items():
            v = var.get()
            final[slot] = None if v == '（不使用）' else v
        self.result = final
        self.destroy()


