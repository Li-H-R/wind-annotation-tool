    def _update_col_map_display(self):
        if not self.col_map:
            self.col_map_label.config(text="尚未加载数据")
            return
        lines = []
        for slot in SLOT_ORDER:
            matched = self.col_map.get(slot)
            if matched:
                short = matched[:20] + ".." if len(matched) > 22 else matched
                lines.append(f"✅ {slot}: {short}")
            else:
