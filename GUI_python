def detect_encoding(path: str) -> str:
    """
    依次尝试常见编码，返回第一个能成功解码文件头的编码。
    优先级: utf-8-sig > utf-8 > gbk > gb2312 > gb18030 > utf-16 > latin-1(兜底)
    若安装了 chardet / charset_normalizer，优先使用其检测结果。
    """
    candidates = ['utf-8-sig', 'utf-8', 'gbk', 'gb2312', 'gb18030', 'utf-16', 'latin-1']
    try:
        import charset_normalizer
        with open(path, 'rb') as f:
            raw = f.read(32768)
        best = charset_normalizer.from_bytes(raw).best()
        if best:
            candidates.insert(0, str(best.encoding))
    except ImportError:
        try:
            import chardet
            with open(path, 'rb') as f:
                raw = f.read(32768)
            det = chardet.detect(raw)
            if det.get('encoding'):
                candidates.insert(0, det['encoding'])
        except ImportError:
            pass
    for enc in candidates:
        try:
            with open(path, 'r', encoding=enc) as f:
                f.read(4096)
            return enc
        except (UnicodeDecodeError, LookupError):
            continue
    return 'latin-1'

