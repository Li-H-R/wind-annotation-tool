    # ════════════════════════════════════
    # 数据加载（★ 全量读取所有列）
    # ════════════════════════════════════
    def _load_csv(self):
        path = filedialog.askopenfilename(
            title="选择 CSV 数据文件",
            filetypes=[("CSV 文件", "*.csv"), ("所有文件", "*.*")])
        if path:
            self._load_single_path(path)

    def _load_single_path(self, path: str):
        try:
            enc = detect_encoding(path)

            # 读取全部列名，弹出确认对话框
            header_df = pd.read_csv(path, nrows=0, encoding=enc)
            all_cols  = list(header_df.columns)
            auto_map  = auto_detect_columns(all_cols)

            dlg = ColumnMappingDialog(self, auto_map, all_cols)
            if dlg.result is None:
                return
            confirmed_map = dlg.result

            active_slots = [s for s in SLOT_ORDER if confirmed_map.get(s)]
            if not active_slots:
                messagebox.showerror("错误", "至少需要映射一个信号列")
                return

            # ★ 读取全部列
            df  = pd.read_csv(path, encoding=enc,
                              na_values=['N/A', '', 'nan', 'NaN'])

            # ★ 剔除前两列（风机名、时间戳）
            df = df.iloc[:, 2:]

            raw = df.to_numpy().astype(np.float32)

            self.all_columns  = list(df.columns)
            self.col_map      = confirmed_map
            self.active_slots = active_slots
            # ★ 记录每个信号槽在全量数组中的列下标
            self.slot_indices = {
                slot: self.all_columns.index(confirmed_map[slot])
                for slot in active_slots
                if confirmed_map.get(slot) in self.all_columns
            }
            self.wind_slot_idx = self.slot_indices.get('风速', -1)

            self._init_windows(raw)
            self._update_col_map_display()
            self._update_col_count_badge()
            self._set_status(
                f"已加载: {Path(path).name}  "
                f"共 {len(raw)} 行  全部 {len(self.all_columns)} 列  "
                f"识别 {len(active_slots)} 个信号"
            )
        except Exception as e:
            messagebox.showerror("加载失败", str(e))

    def _load_multi_csv(self):
        paths = filedialog.askopenfilenames(
            title="批量选择 CSV 文件",
            filetypes=[("CSV 文件", "*.csv"), ("所有文件", "*.*")])
        if not paths:
            return

        # 对第一个文件显示确认对话框，后续文件复用同一映射
        try:
            enc0      = detect_encoding(paths[0])
            header_df = pd.read_csv(paths[0], nrows=0, encoding=enc0)
            all_cols  = list(header_df.columns)
            auto_map  = auto_detect_columns(all_cols)
            dlg = ColumnMappingDialog(self, auto_map, all_cols)
            if dlg.result is None:
                return
            confirmed_map = dlg.result
        except Exception as e:
            messagebox.showerror("读取失败", str(e))
            return

        active_slots = [s for s in SLOT_ORDER if confirmed_map.get(s)]
        if not active_slots:
            messagebox.showerror("错误", "至少需要映射一个信号列")
            return

        # ★ 全量读取所有文件，以第一个文件的列名为基准对齐
        data_list   = []
        ref_columns = None
        for p in paths:
            try:
                enc = detect_encoding(p)
                df  = pd.read_csv(p, encoding=enc,
                                  na_values=['N/A', '', 'nan', 'NaN'])

                # ★ 剔除前两列（风机名、时间戳）
                df = df.iloc[:, 2:]
                if ref_columns is None:
                    ref_columns = list(df.columns)
                else:
                    # 列名不一致时按基准对齐（缺列填 NaN）
                    df = df.reindex(columns=ref_columns)
                data_list.append(df.to_numpy().astype(np.float32))
            except Exception as e:
                messagebox.showwarning("跳过", f"{Path(p).name}: {e}")

        if data_list:
            raw = np.vstack(data_list)
            self.all_columns  = ref_columns
            self.col_map      = confirmed_map
            self.active_slots = active_slots
            self.slot_indices = {
                slot: self.all_columns.index(confirmed_map[slot])
                for slot in active_slots
                if confirmed_map.get(slot) in self.all_columns
            }
            self.wind_slot_idx = self.slot_indices.get('风速', -1)
            self._init_windows(raw)
            self._update_col_map_display()
            self._update_col_count_badge()
            self._set_status(
                f"已加载 {len(paths)} 个文件，共 {len(raw)} 行，"
                f"全部 {len(self.all_columns)} 列，识别 {len(active_slots)} 个信号"
            )

    def _init_windows(self, raw: np.ndarray):
        W, S = self.W_var.get(), self.S_var.get()
        self.windows    = sliding_window(raw, W, S)
        self.cur_idx    = 0
        self.annotation_map = {}
        self.skip_set   = set()
        self._label_index_map: dict = {}
        self._refresh_history_list()
        self._goto(0)
        self._set_status(
            f"分窗完成: {len(self.windows)} 段  窗长={W} 步长={S}  "
            f"每段含 {len(self.all_columns)} 列"
        )

    def _apply_window(self):
        messagebox.showinfo("提示", "请重新加载文件以应用新的分窗参数。")

    def _update_col_count_badge(self):
        n_all  = len(self.all_columns)
        n_show = len(self.active_slots)
        self.col_count_badge.config(
            text=f"📦 全量: {n_all} 列  |  显示: {n_show} 列")

    # ════════════════════════════════════
    # 图表渲染（★ 通过 slot_indices 精确取列）
    # ════════════════════════════════════
    def _refresh_chart(self):
        if len(self.windows) == 0 or not self.active_slots:
            return
        seg    = self.windows[self.cur_idx]   # shape: (W, n_all_columns)
        n_dims = len(self.active_slots)

        self.fig.clear()
        if n_dims == 0:
            self.canvas.draw()
            return

        axes = self.fig.subplots(n_dims, 1, sharex=True)
        if n_dims == 1:
            axes = [axes]

        time_axis = np.arange(seg.shape[0])
        for plot_i, slot in enumerate(self.active_slots):
            col_idx = self.slot_indices.get(slot, -1)
            if col_idx < 0 or col_idx >= seg.shape[1]:
                continue

            color = SLOT_COLORS.get(slot, '#AAAAAA')
            ax    = axes[plot_i]
            ax.set_facecolor("#1A1A2E")
            ax.tick_params(colors="#888", labelsize=7)
            for spine in ax.spines.values():
                spine.set_color("#333355")

            y = seg[:, col_idx]   # ★ 全量数组中精确定位
            ax.plot(time_axis, y, color=color, linewidth=1.0)
            ax.fill_between(time_axis, y, alpha=0.12, color=color)

            orig_col   = self.col_map.get(slot, slot)
            label_text = (f"{slot}" if slot == orig_col
                          else f"{slot}\n({orig_col[:10]})")
            ax.set_ylabel(label_text, color="#AAA", fontsize=6)
            ax.grid(True, alpha=0.15, color="#444466")

            if self.show_stats.get():
                mn, mx, av = np.nanmin(y), np.nanmax(y), np.nanmean(y)
                ax.axhline(av, color="#FFD700", linewidth=0.6,
                           linestyle="--", alpha=0.6)
                ax.text(0.99, 0.92,
                        f"avg={av:.2f}  min={mn:.2f}  max={mx:.2f}",
                        transform=ax.transAxes, fontsize=6,
                        color="#AAA", ha="right", va="top")

        axes[-1].set_xlabel("时间步", color="#AAA", fontsize=8)
        self.fig.patch.set_facecolor("#1E1E2E")
        self.canvas.draw()

        # 信息栏
        wind_level = infer_wind_level(seg, self.wind_slot_idx)
        self.seg_info_label.config(
            text=f"片段 {self.cur_idx + 1} / {len(self.windows)}")
        self.wind_badge.config(text=wind_level)
        self.wind_level_var.set(wind_level)

        stats_parts = [
            f"{slot[:4]}={np.nanmean(seg[:, self.slot_indices[slot]]):.2f}"
            for slot in self.active_slots if slot in self.slot_indices
        ]
        self.stats_label.config(text="  |  ".join(stats_parts))

        existing = self.annotation_map.get(self.cur_idx, "")
        self.cur_label_badge.config(
            text=(f"✅ {existing}" if existing
                  else ("⏭ 已跳过" if self.cur_idx in self.skip_set else "")),
            fg="#4CAF50" if existing else "#FF9800"
        )

    def _update_progress(self):
        n = len(self.windows)
        if n == 0:
            return
        annotated = len(self.annotation_map)
        skipped   = len(self.skip_set)
        self.progress_bar["maximum"] = n
        self.progress_bar["value"]   = annotated + skipped
        self.progress_label.config(text=f"{self.cur_idx + 1} / {n}")
        self.annotated_label.config(
            text=f"已标注: {annotated}  跳过: {skipped}")

    def _update_annotated_list(self):
        self.annotated_list.delete(0, tk.END)
        for idx in sorted(self.annotation_map.keys()):
            lbl   = self.annotation_map[idx]
            short = lbl[:28] + ".." if len(lbl) > 30 else lbl
            self.annotated_list.insert(tk.END, f"[{idx+1:4d}] {short}")

    def _refresh_history_list(self):
        self.history_list.delete(0, tk.END)
        for k, v in sorted(self.label_db.items(),
                            key=lambda x: -x[1].get('count', 0)):
            cnt = v.get('count', 0)
            self.history_list.insert(tk.END, f"({cnt:3d}) {k}")

    # ════════════════════════════════════
    # 导航
    # ════════════════════════════════════
    def _goto(self, idx: int):
        if len(self.windows) == 0:
            return
        self.cur_idx = max(0, min(idx, len(self.windows) - 1))
        self._refresh_chart()
        self._update_progress()

    def _next(self): self._goto(self.cur_idx + 1)
    def _prev(self): self._goto(self.cur_idx - 1)

    def _jump_to(self):
        try:
            idx = int(self.jump_entry.get()) - 1
            self._goto(idx)
        except ValueError:
            messagebox.showwarning("输入错误", "请输入有效的片段序号")

    def _on_list_select(self, event):
        sel = self.annotated_list.curselection()
        if not sel:
            return
        text = self.annotated_list.get(sel[0])
        try:
            idx = int(text[1:5].strip()) - 1
            self._goto(idx)
        except Exception:
            pass

    # ════════════════════════════════════
    # 标注操作
    # ════════════════════════════════════
    def _get_label_from_ui(self) -> str:
        custom = self.custom_label_entry.get().strip()
        if custom:
            return custom
        wl = (self.wind_level_var.get() or
              infer_wind_level(self.windows[self.cur_idx], self.wind_slot_idx))
        ft = self.fault_type_var.get() or "未知"
        return f"{wl}_{ft}"

    def _confirm_label(self):
        if len(self.windows) == 0:
            return
        label  = self._get_label_from_ui()
        remark = self.remark_entry.get().strip()
        if not label:
            messagebox.showwarning("提示", "请选择或输入标签")
            return

        self.annotation_map[self.cur_idx] = label
        self.skip_set.discard(self.cur_idx)
        if not hasattr(self, '_label_index_map'):
            self._label_index_map = {}
        self._label_index_map[self.cur_idx] = label

        if label not in self.label_db:
            self.label_db[label] = {'count': 0, 'remark': remark}
        self.label_db[label]['count'] = self.label_db[label].get('count', 0) + 1
        if remark:
            self.label_db[label]['remark'] = remark
        save_label_db(self.label_db)

        self._update_annotated_list()
        self._update_progress()
        self._refresh_history_list()
        self._set_status(f"片段 {self.cur_idx + 1} → 标注: {label}")

        self.custom_label_entry.delete(0, tk.END)
        self.remark_entry.delete(0, tk.END)

        if self.auto_advance.get():
            self._next()
        else:
            self._refresh_chart()

    def _skip(self):
        if len(self.windows) == 0:
            return
        self.skip_set.add(self.cur_idx)
        self._set_status(f"片段 {self.cur_idx + 1} → 跳过")
        self._update_progress()
        if self.auto_advance.get():
            self._next()
        else:
            self._refresh_chart()

    def _delete_label(self):
        if self.cur_idx in self.annotation_map:
            label = self.annotation_map.pop(self.cur_idx)
            if hasattr(self, '_label_index_map'):
                self._label_index_map.pop(self.cur_idx, None)
            self._set_status(f"片段 {self.cur_idx + 1} 标注已删除 (原: {label})")
            self._update_annotated_list()
            self._update_progress()
            self._refresh_chart()

    def _apply_history_label(self, event):
        sel = self.history_list.curselection()
        if not sel:
            return
        text  = self.history_list.get(sel[0])
        label = text[6:].strip()
        parts = label.split("_", 1)
        if len(parts) == 2:
            self.wind_level_var.set(parts[0])
            self.fault_type_var.set(
                parts[1] if parts[1] in PRESET_FAULT_TYPES else "")
            self.custom_label_entry.delete(0, tk.END)
        else:
            self.custom_label_entry.delete(0, tk.END)
            self.custom_label_entry.insert(0, label)

    # ════════════════════════════════════
    # ★ 保存结果：全量列 CSV
    # ════════════════════════════════════
        # ════════════════════════════════════
        # 保存结果：导出为字典格式的 .npy 文件
        # ════════════════════════════════════
    def _save_results(self):
        if not self.annotation_map:
            messagebox.showinfo("提示", "尚无标注数据")
            return
        if not self.all_columns:
            messagebox.showerror("错误", "数据缺失，请重新加载数据")
            return

        # 1. 弹出保存对话框
        path = filedialog.asksaveasfilename(
            title="保存标注结果为 npy 字典",
            defaultextension=".npy",
            filetypes=[("NumPy 文件", "*.npy")],
            initialfile="labeled_dataset.npy"
        )
        if not path:
            return

        # 2. 构建字典 {label: np.ndarray}
        # 结果结构：{ "标签1": array(N, W, D), "标签2": array(M, W, D) ... }
        result_dict = {}

        # 找出所有已使用的唯一标签
        unique_labels = set(self.annotation_map.values())

        for target_label in unique_labels:
            # 筛选出属于当前标签的所有片段索引
            indices = [idx for idx, lbl in self.annotation_map.items() if lbl == target_label]

            # 从 self.windows 中提取这些片段
            # self.windows 的 shape 是 (Total_Segments, W, D)
            label_data = self.windows[indices]

            result_dict[target_label] = label_data

        try:
            # 3. 保存为 npy 文件
            np.save(path, result_dict)

            # 4. 统计信息并提示
            stats_str = "\n".join([f" - {lbl}: {data.shape[0]} 个片段" for lbl, data in result_dict.items()])
            messagebox.showinfo(
                "保存成功",
                f"已保存至: {os.path.basename(path)}\n\n标签统计:\n{stats_str}"
            )
            self._set_status(f"字典格式 npy 已保存: {os.path.basename(path)}")

        except Exception as e:
            messagebox.showerror("保存失败", f"导出 npy 时发生错误:\n{str(e)}")

    # ════════════════════════════════════
    # 统计 & 辅助
    # ════════════════════════════════════
    def _show_summary(self):
        if not self.annotation_map:
            messagebox.showinfo("统计", "尚无标注数据")
            return
        from collections import Counter
        counter = Counter(self.annotation_map.values())
        lines = [
            f"总片段数:   {len(self.windows)}",
            f"已标注:     {len(self.annotation_map)}",
            f"跳过:       {len(self.skip_set)}",
            f"全量列数:   {len(self.all_columns)}",
            "",
            f"识别信号 ({len(self.active_slots)} 个):"
        ]
        for slot in self.active_slots:
            orig = self.col_map.get(slot, '?')
            idx  = self.slot_indices.get(slot, -1)
            lines.append(f"  [{idx:3d}] {slot} ← {orig}")
        lines += ["", "各类标签分布:"]
        for label, cnt in counter.most_common():
            lines.append(f"  [{cnt:4d}] {label}")
        messagebox.showinfo("标注统计", "\n".join(lines))

    def _reset_annotations(self):
        if messagebox.askyesno("确认", "确定要清空所有标注？此操作不可撤销。"):
            self.annotation_map   = {}
            self.skip_set         = set()
            self._label_index_map = {}
            self._update_annotated_list()
            self._update_progress()
            self._refresh_chart()
            self._set_status("标注已全部清除")

    def _set_status(self, msg: str):
        self.statusbar.config(text=f"  {msg}")

    def _on_close(self):
        if self.annotation_map:
            if messagebox.askyesno("退出确认", "标注数据尚未保存，是否退出？"):
                self.destroy()
        else:
            self.destroy()


